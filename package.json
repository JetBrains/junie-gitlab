{
  "name": "gitlab-cli-wrapper",
  "version": "0.1.0",
  "private": true,
  "description": "",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "gitlab-runner-image": "dist/cli.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "start": "node dist/cli.js",
    "test:unit": "npx tsx --test tests/unit/*.test.ts",
    "test:integration": "node --env-file=.env.local-gitlab --import tsx --test tests/integration/*.test.ts",
    "wrapper:build": "docker build -t junie-gitlab-wrapper:test .",
    "gitlab:up": "npm run wrapper:build && docker compose -f docker-compose.test.yml up -d && ./scripts/bootstrap-local-gitlab.sh",
    "gitlab:down": "./scripts/teardown-local-gitlab.sh"
  },
  "dependencies": {
    "@gitbeaker/rest": "^43.8.0",
    "commander": "^12.1.0",
    "simple-git": "^3.30.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
